# JusticeAI 统一环境变量示例
#
# 用法：复制本文件为仓库根目录 `.env`，再按本机环境修改。
# 后端会优先读取仓库根目录 `.env`，其次回退读取 `backend-rust/.env`。
# 前端 Vite 也会从仓库根目录读取 `VITE_*` 配置。
#
# 命名规则：
# - 后端配置覆盖项使用 SECTION__FIELD 的双下划线写法，对应 backend-rust/config/*.toml
# - 前端配置使用 VITE_* 前缀

# ===== 通用运行环境 =====
APP_ENV=development
RUST_LOG=info,sqlx=warn,tower_http=info

# ===== 后端应用 =====
APP__NAME=JusticeAI Backend
APP__HOST=127.0.0.1
APP__PORT=8088
APP__ENV=development

# ===== PostgreSQL =====
DATABASE__URL=postgres://justiceai:justiceai@127.0.0.1:5432/justiceai
DATABASE__MAX_CONNECTIONS=10
DATABASE__ACQUIRE_TIMEOUT_SECS=5

# ===== HugeGraph =====
HUGEGRAPH__BASE_URL=http://127.0.0.1:8080
HUGEGRAPH__GREMLIN_URL=ws://127.0.0.1:8182/gremlin
HUGEGRAPH__USERNAME=admin
HUGEGRAPH__PASSWORD=admin

# ===== Milvus =====
MILVUS__ADDRESS=http://127.0.0.1:19530

# ===== vLLM =====
VLLM__BASE_URL=http://127.0.0.1:8000/v1
VLLM__MODEL_NAME=Qwen2.5-32B-Instruct-AWQ

# ===== 本地文件存储 =====
STORAGE__UPLOAD_DIR=./runtime/uploads
STORAGE__REPORT_DIR=./runtime/reports
STORAGE__TRAINING_DIR=./runtime/training

# ===== 前端开发配置 =====
# 浏览器里 API 请求默认走 /api，开发期由 Vite 代理到后端
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8088
VITE_DEV_HOST=127.0.0.1
VITE_DEV_PORT=18100
